        <mxCell id="HvBbE6DFLtQefyfHHWWZ-16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;caret-color: rgba(0, 0, 0, 0.85); color: rgba(0, 0, 0, 0.85); font-family: &amp;quot;YS Text&amp;quot;, sans-serif; white-space-collapse: preserve-breaks; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Обоснование: эти данные могут использоваться злоумышленниками для проведения атак на инфраструктуру компании.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
